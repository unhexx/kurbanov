# Database
DATABASE_URL=postgresql+psycopg://consultant:consultant@localhost:5432/consultant

# Telegram
TELEGRAM_BOT_TOKEN=replace_me

# Optional: restrict webhook calls from Telegram
TELEGRAM_WEBHOOK_SECRET_TOKEN=replace_me_or_leave_empty

# Optional: manager notifications
TELEGRAM_MANAGER_CHAT_ID=

# Admin API
# If empty, admin endpoints are open (development only). For any shared/stage/prod environment set a token.
ADMIN_API_TOKEN=replace_me

# Внешний сервис формирования ответов консультанта.
# Реальный ключ хранится только в локальном .env (gitignored).
PERPLEXITY_API_KEY=replace_me
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar-pro
PERPLEXITY_MAX_TOKENS=800
PERPLEXITY_TEMPERATURE=0.2
PERPLEXITY_TIMEOUT_SECONDS=30
PERPLEXITY_MAX_RETRIES=2

# Бюджетный порог для подбора (RUB). Ниже — передача менеджеру.
BUDGET_THRESHOLD_RUB=1500000

# Размер истории диалога, передаваемый во внешний сервис.
CONSULTANT_HISTORY_LIMIT=12
